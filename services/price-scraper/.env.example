# EasyRest Scraper Configuration
# Copy this file to .env and configure

# Server port
PORT=3456

# Security token (REQUIRED - generate a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EASYREST_TOKEN=your_secret_token_here

# Default Booking.com hotel URL
DEFAULT_HOTEL_URL=https://www.booking.com/hotel/it/easy-rest-affitti-brevi-italia.fr.html

# Puppeteer settings
HEADLESS=true
TIMEOUT=40000

# Rate limiting (requests per minute per IP)
RATE_LIMIT=10

# Debug mode (true/false)
DEBUG=false

# ── Endpoint public /quote (appelé par le site Astro) ───────────────────────
# Remise appliquée au prix Booking : prix direct = booking × (1 - 15/100)
DISCOUNT_PERCENT=15
# Nombre de nuits maximum accepté
MAX_NIGHTS=30
# Durée du cache des devis, en secondes (limite les scrapes réels)
QUOTE_CACHE_TTL=1800
# Origines autorisées (CORS), séparées par des virgules — le domaine du site
ALLOWED_ORIGINS=https://easyrest.eu,https://www.easyrest.eu
