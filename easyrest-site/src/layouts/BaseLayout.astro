---
import { type Lang, langList } from '../i18n/ui';
import { SITE } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import '../styles/global.css';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Map langue -> chemin absolu de la version traduite (pour hreflang + sélecteur). */
  alternates: Record<Lang, string>;
  /** JSON-LD optionnel (objet ou tableau d'objets schema.org). */
  jsonLd?: object;
  image?: string;
  /** Émet <meta name="robots" content="noindex"> quand true. */
  noindex?: boolean;
}

const { lang, title, description, alternates, jsonLd, image, noindex } = Astro.props;
const canonical = new URL(alternates[lang], SITE.url).href;
const ogImage = new URL(image ?? '/og.jpg', SITE.url).href;
const fullTitle = `${title} · ${SITE.name}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />

    {/* hreflang : relie les versions linguistiques entre elles (corrige le SEO multilingue actuel) */}
    {langList.map((l) => (
      <link rel="alternate" hreflang={l} href={new URL(alternates[l], SITE.url).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(alternates.fr, SITE.url).href} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={lang} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} — ${lang}`} href={`/${lang}/rss.xml`} />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    {/* Google Ads + Consent Mode v2 — chargé uniquement si configuré dans config.ts.
        Par défaut tout est REFUSÉ ; mis à « granted » seulement après acceptation (bandeau). */}
    {SITE.googleAds.id && (
      <>
        <script
          set:html={`
            window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
            var __c=null;try{__c=localStorage.getItem('er-consent');}catch(e){}
            gtag('consent','default',{ad_storage:'denied',analytics_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',wait_for_update:500});
            if(__c==='granted'){gtag('consent','update',{ad_storage:'granted',analytics_storage:'granted',ad_user_data:'granted',ad_personalization:'granted'});}
            gtag('js', new Date());
            gtag('config', ${JSON.stringify(SITE.googleAds.id)});
            ${
              SITE.googleAds.waConversionLabel
                ? `document.addEventListener('click', function(e){ var t=e.target; var a=(t&&t.closest)?t.closest('a[href*="wa.me"]'):null; if(a){ gtag('event','conversion',{send_to:${JSON.stringify(SITE.googleAds.id + '/' + SITE.googleAds.waConversionLabel)}}); } });`
                : ''
            }
          `}
        />
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.googleAds.id}`}></script>
      </>
    )}
  </head>
  <body>
    <Header lang={lang} alternates={alternates} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    {SITE.googleAds.id && <ConsentBanner lang={lang} />}
  </body>
</html>
