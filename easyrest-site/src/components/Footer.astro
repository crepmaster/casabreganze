---
import { t, type Lang } from '../i18n/ui';
import { SITE } from '../config';
const { lang } = Astro.props as { lang: Lang };
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>© {year} {SITE.name} — {t(lang, 'footer.rights')}</p>
  <p class="addr">{SITE.address}</p>
</footer>

<style>
  .site-footer {
    margin-top: 4rem; padding: 2rem clamp(1rem, 4vw, 3rem);
    border-top: 1px solid var(--line); color: var(--muted); font-size: 0.9rem;
  }
  .site-footer .addr { margin-top: 0.25rem; }
</style>
