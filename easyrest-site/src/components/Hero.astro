---
import { Image } from 'astro:assets';
import { t, type Lang } from '../i18n/ui';
import { heroPhoto } from '../lib/gallery';

const { lang } = Astro.props as { lang: Lang };

const seePhotos: Record<Lang, string> = {
  fr: 'Voir les photos',
  en: 'See the photos',
  it: 'Vedi le foto',
  es: 'Ver las fotos',
};
const alt: Record<Lang, string> = {
  fr: 'Salon lumineux de l’appartement EasyRest à Milan',
  en: 'Bright living room of the EasyRest apartment in Milan',
  it: 'Soggiorno luminoso dell’appartamento EasyRest a Milano',
  es: 'Salón luminoso del apartamento EasyRest en Milán',
};
---

<section class="hero full-bleed">
  <Image
    src={heroPhoto.src}
    alt={alt[lang]}
    class="hero__img"
    widths={[720, 1080, 1600, 2000]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero__scrim"></div>
  <div class="hero__inner">
    <p class="hero__loc">Milano · Italia</p>
    <h1>{t(lang, 'hero.title')}</h1>
    <p class="hero__sub">{t(lang, 'hero.subtitle')}</p>
    <div class="hero__cta">
      <a class="btn btn-primary" href="#reserver">{t(lang, 'booking.cta_whatsapp')}</a>
      <a class="btn btn-ghost" href="#galerie">{seePhotos[lang]}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(30rem, 78vh, 46rem);
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
  }
  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, rgba(15, 16, 20, 0.72) 0%, rgba(15, 16, 20, 0.28) 45%, rgba(15, 16, 20, 0.1) 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max);
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
  }
  .hero__loc {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    opacity: 0.9;
  }
  .hero h1 {
    margin: 0;
    max-width: 16ch;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
  }
  .hero__sub {
    max-width: 42ch;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    margin: 0.9rem 0 1.6rem;
    opacity: 0.95;
  }
  .hero__cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .btn-ghost {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
  }
  .btn-ghost:hover { background: rgba(255, 255, 255, 0.24); }
</style>
