---
import { t, type Lang } from '../i18n/ui';
import { SITE } from '../config';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
  alternates: Record<Lang, string>;
}
const { lang, alternates } = Astro.props;

const menuLabel: Record<Lang, string> = { fr: 'Menu', en: 'Menu', it: 'Menu', es: 'Menú' };
---

<header class="site-header" id="site-header">
  <a class="brand" href={`/${lang}/`}>{SITE.name}</a>

  <button
    class="menu-toggle"
    id="menu-toggle"
    type="button"
    aria-label={menuLabel[lang]}
    aria-expanded="false"
    aria-controls="nav-panel"
  >
    <span class="bars" aria-hidden="true"></span>
  </button>

  <div class="nav-panel" id="nav-panel">
    <nav class="main-nav" aria-label="Navigation">
      <a href={`/${lang}/`}>{t(lang, 'nav.home')}</a>
      <a href={`/${lang}/guides/`}>{t(lang, 'nav.guides')}</a>
    </nav>
    <LanguageSwitcher lang={lang} alternates={alternates} />
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  if (header && toggle) {
    toggle.addEventListener('click', () => {
      const open = header.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // Referme le menu au clic sur un lien (nav ou langue).
    header.querySelectorAll('.nav-panel a').forEach((a) =>
      a.addEventListener('click', () => {
        header.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }),
    );
  }
</script>

<style>
  .site-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem clamp(1rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    z-index: 20;
  }
  .brand {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--ink);
    text-decoration: none;
    margin-right: auto;
  }
  .nav-panel { display: flex; align-items: center; gap: 1.5rem; }
  .main-nav { display: flex; gap: 1.25rem; }
  .main-nav a { color: var(--ink); text-decoration: none; font-weight: 500; }
  .main-nav a:hover { color: var(--accent); }

  /* Bouton hamburger — masqué sur desktop */
  .menu-toggle {
    display: none;
    width: 2.6rem;
    height: 2.6rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg);
    cursor: pointer;
    place-items: center;
  }
  .bars, .bars::before, .bars::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .bars { position: relative; }
  .bars::before { position: absolute; top: -6px; left: 0; }
  .bars::after { position: absolute; top: 6px; left: 0; }

  @media (max-width: 720px) {
    .menu-toggle { display: grid; }
    .nav-panel {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.1rem;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
      padding: 1.25rem clamp(1rem, 4vw, 3rem);
      box-shadow: var(--shadow);
    }
    .site-header.open .nav-panel { display: flex; }
    .main-nav { flex-direction: column; gap: 0.9rem; font-size: 1.05rem; }

    /* Hamburger → croix quand ouvert */
    .site-header.open .bars { background: transparent; }
    .site-header.open .bars::before { transform: translateY(6px) rotate(45deg); }
    .site-header.open .bars::after { transform: translateY(-6px) rotate(-45deg); }
  }
</style>
