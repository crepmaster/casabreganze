---
import { t, type Lang } from '../i18n/ui';
import { SITE } from '../config';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
  alternates: Record<Lang, string>;
}
const { lang, alternates } = Astro.props;
---

<header class="site-header">
  <a class="brand" href={`/${lang}/`}>{SITE.name}</a>
  <nav class="main-nav" aria-label="Navigation">
    <a href={`/${lang}/`}>{t(lang, 'nav.home')}</a>
    <a href={`/${lang}/guides/`}>{t(lang, 'nav.guides')}</a>
  </nav>
  <LanguageSwitcher lang={lang} alternates={alternates} />
</header>

<style>
  .site-header {
    display: flex; align-items: center; gap: 1.5rem;
    padding: 1rem clamp(1rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
    position: sticky; top: 0; background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px); z-index: 10;
  }
  .brand { font-weight: 700; font-size: 1.15rem; color: var(--ink); text-decoration: none; }
  .main-nav { display: flex; gap: 1.25rem; margin-right: auto; }
  .main-nav a { color: var(--ink); text-decoration: none; font-weight: 500; }
  .main-nav a:hover { color: var(--accent); }
</style>
