---
import type { Lang } from '../i18n/ui';

const { lang } = Astro.props as { lang: Lang };

const head: Record<Lang, { eyebrow: string; title: string }> = {
  fr: { eyebrow: 'Le logement', title: 'Tout le confort d’un chez-soi' },
  en: { eyebrow: 'The home', title: 'All the comforts of home' },
  it: { eyebrow: 'L’alloggio', title: 'Tutti i comfort di casa' },
  es: { eyebrow: 'El alojamiento', title: 'Todas las comodidades de un hogar' },
};

// Caractéristiques chiffrées (surface / capacité / chambres / étage).
const specs: Record<Lang, { value: string; label: string }[]> = {
  fr: [
    { value: '70', label: 'm² habitables' },
    { value: '4', label: 'voyageurs' },
    { value: '1', label: 'chambre' },
    { value: '5ᵉ', label: 'étage avec ascenseur' },
  ],
  en: [
    { value: '70', label: 'm² of space' },
    { value: '4', label: 'guests' },
    { value: '1', label: 'bedroom' },
    { value: '5th', label: 'floor with lift' },
  ],
  it: [
    { value: '70', label: 'm² abitabili' },
    { value: '4', label: 'ospiti' },
    { value: '1', label: 'camera' },
    { value: '5°', label: 'piano con ascensore' },
  ],
  es: [
    { value: '70', label: 'm² habitables' },
    { value: '4', label: 'huéspedes' },
    { value: '1', label: 'dormitorio' },
    { value: '5º', label: 'piso con ascensor' },
  ],
};

const amenities: Record<Lang, string[]> = {
  fr: ['Wifi haut débit', 'Cuisine entièrement équipée', 'Salle de bain privative', 'Balcon', 'Linge de maison fourni', 'Accès métro à pied'],
  en: ['High-speed Wi-Fi', 'Fully equipped kitchen', 'Private bathroom', 'Balcony', 'Linens provided', 'Metro within walking distance'],
  it: ['Wi-Fi ad alta velocità', 'Cucina completamente attrezzata', 'Bagno privato', 'Balcone', 'Biancheria fornita', 'Metro a piedi'],
  es: ['Wifi de alta velocidad', 'Cocina totalmente equipada', 'Baño privado', 'Balcón', 'Ropa de casa incluida', 'Metro a pie'],
};

const h = head[lang];
---

<section class="amenities section-pad section-surface full-bleed">
  <div class="inner">
    <div class="section-head">
      <span class="eyebrow">{h.eyebrow}</span>
      <h2>{h.title}</h2>
    </div>

    <div class="specs">
      {specs[lang].map((s) => (
        <div class="spec">
          <span class="spec__value">{s.value}</span>
          <span class="spec__label">{s.label}</span>
        </div>
      ))}
    </div>

    <ul class="amlist">
      {amenities[lang].map((a) => (
        <li>
          <svg viewBox="0 0 20 20" aria-hidden="true" width="18" height="18">
            <path
              d="M5 10.5l3 3 7-7"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span>{a}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .inner { max-width: var(--max); margin: 0 auto; padding: 0 clamp(1rem, 4vw, 3rem); }
  .specs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }
  .spec {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.4rem 1rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .spec__value { display: block; font-size: clamp(1.8rem, 4vw, 2.4rem); font-weight: 700; color: var(--accent); line-height: 1; }
  .spec__label { display: block; color: var(--muted); font-size: 0.9rem; margin-top: 0.4rem; }

  .amlist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem 1.5rem;
    max-width: 760px;
    margin-inline: auto;
  }
  .amlist li { display: flex; align-items: center; gap: 0.7rem; }
  .amlist svg {
    flex: none;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: 50%;
    padding: 5px;
    box-sizing: content-box;
  }
</style>
