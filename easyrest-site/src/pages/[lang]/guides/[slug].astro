---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { t, langList, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const all = await getCollection('guides', (e) => !e.data.draft);
  return all.map((entry) => ({
    params: { lang: entry.data.lang, slug: entry.data.translationKey },
    props: { entry, all },
  }));
}

const { entry, all } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);

// hreflang : pour chaque langue, l'URL de la version traduite si elle existe (sinon repli vers l'index)
const alternates = Object.fromEntries(
  langList.map((l) => {
    const tr = all.find((e) => e.data.translationKey === entry.data.translationKey && e.data.lang === l);
    return [l, tr ? `/${l}/guides/${tr.data.translationKey}/` : `/${l}/guides/`];
  }),
) as Record<Lang, string>;

const seoTitle = entry.data.seo?.title ?? entry.data.title;
---

<BaseLayout lang={lang} title={seoTitle} description={entry.data.description} alternates={alternates}>
  <article class="guide">
    <a href={`/${lang}/guides/`}>{t(lang, 'guides.back')}</a>
    <h1>{entry.data.title}</h1>
    <time datetime={entry.data.pubDate.toISOString()}>{entry.data.pubDate.toLocaleDateString(lang)}</time>
    <Content />
  </article>
</BaseLayout>
