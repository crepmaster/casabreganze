---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import Amenities from '../../components/Amenities.astro';
import BookingBlock from '../../components/BookingBlock.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import GuidesTeaser from '../../components/GuidesTeaser.astro';
import { t, langList, type Lang } from '../../i18n/ui';
import { indexAlternates } from '../../i18n/paths';
import { SITE } from '../../config';

export function getStaticPaths() {
  return langList.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;

const alternates = indexAlternates('/');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: SITE.name,
  url: new URL(`/${lang}/`, SITE.url).href,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address,
    addressLocality: 'Milano',
    addressCountry: 'IT',
  },
  geo: { '@type': 'GeoCoordinates', latitude: SITE.geo.lat, longitude: SITE.geo.lng },
  priceRange: '€€',
};
---

<BaseLayout
  lang={lang}
  title={t(lang, 'hero.title')}
  description={t(lang, 'hero.subtitle')}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <Hero lang={lang} />
  <Gallery lang={lang} />
  <Amenities lang={lang} />

  <div class="section-pad">
    <div class="booking-row">
      <BookingBlock lang={lang} />
      <AvailabilityCalendar lang={lang} />
    </div>
  </div>

  <GuidesTeaser lang={lang} />
</BaseLayout>
