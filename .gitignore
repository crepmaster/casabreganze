# WordPress repo: track only custom theme & plugins
*
!.gitignore

# Project documentation (planning, refactoring, architecture)
!docs/
!docs/**

# New Astro site (greenfield, replaces WordPress) — track source, ignore build artifacts
!easyrest-site/
!easyrest-site/**
easyrest-site/node_modules/
easyrest-site/dist/
easyrest-site/.astro/

# Allow wp-content tree
!wp-content/
wp-content/*

# Theme
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/easyrest-child/
wp-content/themes/easyrest-child/*
!wp-content/themes/easyrest-child/**

# Plugins
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/easyrest-core/
wp-content/plugins/easyrest-core/*
!wp-content/plugins/easyrest-core/**
!wp-content/plugins/easyrest-content-engine/
wp-content/plugins/easyrest-content-engine/*
!wp-content/plugins/easyrest-content-engine/**

# Exclude heavy/secret plugin subfolders
wp-content/plugins/easyrest-core/scraper-node/node_modules/
wp-content/plugins/easyrest-core/scraper-node/.env
wp-content/plugins/easyrest-core/scraper-node/logs/